#!/usr/bin/env bash
set -euo pipefail

# Clean up orphaned test containers from previous interrupted runs
orphans=$(docker ps -q --filter "label=com.betweenrows.test" 2>/dev/null || true)
if [ -n "$orphans" ]; then
    echo "→ cleaning up orphaned test containers"
    docker rm -f $orphans >/dev/null 2>&1 || true
fi

echo "→ cargo fmt --check"
cargo fmt --check

echo "→ cargo clippy -p proxy"
cargo clippy -p proxy -- -D warnings

echo "→ cargo test -p proxy"
cargo test -p proxy

echo "→ admin-ui typecheck"
(cd admin-ui && npm run typecheck)

echo "→ admin-ui tests"
(cd admin-ui && npm run test:run)

# Only run docs-site checks if files under docs-site/ are staged AND the
# docs-site deps are installed (first clone won't have them yet).
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^docs-site/'; then
  if [ -d "docs-site/node_modules" ]; then
    echo "→ docs-site vitepress build"
    (cd docs-site && npm run build)
  else
    echo "→ docs-site has staged changes but node_modules is missing; skipping build check"
    echo "  Run 'cd docs-site && npm ci' once to enable docs checks in the hook."
  fi
fi
